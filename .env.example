# ================================================================
#  BINANCE WS → n8n BRIDGE — KONFIGURASI LENGKAP
#  Di Dokploy: masukkan key-value ini di tab "Environment Variables"
# ================================================================

# ----------------------------------------------------------------
# [WAJIB] n8n Webhook URL
# ----------------------------------------------------------------
# URL Production webhook dari n8n (bukan webhook-test)
N8N_WEBHOOK_URL=https://your-n8n.com/webhook/crypto-signal

# ----------------------------------------------------------------
# [FILTER] Pre-filter sebelum data dikirim ke n8n
# ----------------------------------------------------------------

# Minimum % perubahan harga 24h (absolut) untuk trigger
# Rekomendasi: 3 (tangkap semua pergerakan signifikan, n8n yang seleksi detail)
PRICE_CHANGE_THRESHOLD=3

# Pengganda volume spike. 0 = NONAKTIF
# Contoh: 2 = trigger hanya jika volume 2x rata-rata
VOLUME_SPIKE_MULTIPLIER=0

# Cooldown per koin (milidetik) setelah trigger
# 300000 = 5 menit | 180000 = 3 menit | 60000 = 1 menit
COOLDOWN_MS=180000

# ----------------------------------------------------------------
# [PAIRS] Koin yang dipantau
# ----------------------------------------------------------------

# "top100" = 100 Futures pair terpopuler (default)
# "custom" = hanya yang ada di CUSTOM_PAIRS
PAIRS_MODE=top100

# Pair kustom (pisahkan koma, tanpa spasi)
CUSTOM_PAIRS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT

# ----------------------------------------------------------------
# [SERVER]
# ----------------------------------------------------------------
PORT=3000

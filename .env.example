# ================================================================
#  BINANCE WS → n8n BRIDGE — ENVIRONMENT VARIABLES
#  Semua konfigurasi dilakukan DI SINI.
#  Di Dokploy: masukkan key-value ini di tab "Environment Variables"
# ================================================================

# ----------------------------------------------------------------
# [WAJIB] URL Webhook dari node "Webhook" di n8n Anda
# ----------------------------------------------------------------
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/binance-alert

# ----------------------------------------------------------------
# [OPSIONAL] Filter — kapan koin dianggap "panas"
# ----------------------------------------------------------------

# Minimum % perubahan harga (absolut, naik ATAU turun) untuk trigger
# Default: 3.0  |  Contoh: 2.5 untuk lebih sensitif, 5.0 untuk lebih selektif
PRICE_CHANGE_THRESHOLD=3.0

# Pengganda volume spike. Set 0 untuk MENONAKTIFKAN filter volume.
# Contoh: 2 = hanya trigger jika volume 2x rata-rata historical
# Default: 0 (nonaktif)
VOLUME_SPIKE_MULTIPLIER=0

# Jeda (cooldown) dalam milidetik per koin setelah trigger
# Default: 300000 (5 menit)  |  60000 = 1 menit  |  0 = tanpa cooldown
COOLDOWN_MS=300000

# ----------------------------------------------------------------
# [OPSIONAL] Pairs / Koin yang dipantau
# ----------------------------------------------------------------

# "top100" = otomatis pantau 100 Futures pair terpopuler (default)
# "custom" = gunakan daftar CUSTOM_PAIRS di bawah
PAIRS_MODE=top100

# Daftar koin kustom (hanya aktif jika PAIRS_MODE=custom)
# Pisahkan dengan koma, tanpa spasi
CUSTOM_PAIRS=BTCUSDT,ETHUSDT,BNBUSDT,SOLUSDT,XRPUSDT

# ----------------------------------------------------------------
# [OPSIONAL] Server
# ----------------------------------------------------------------

# Port Express (default: 3000)
PORT=3000
